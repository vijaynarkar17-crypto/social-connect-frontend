# Social Connect — Frontend environment variables
# Copy this file to `.env`. NEVER commit `.env`.

# Local dev: leave empty — Vite proxies /api to http://localhost:4000
# Production (Vercel): set to your deployed backend URL, e.g. https://your-api.onrender.com
VITE_API_URL=

# Optional: Google sign-in client ID (public, safe to expose)
VITE_GOOGLE_CLIENT_ID=
